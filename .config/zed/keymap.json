[
  {
    "context": "Workspace",
    "bindings": {
      "esc": "workspace::ActivateNextPane",
      "ctrl-w": "workspace::ActivateNextPane"
    }
  },
  {
    // not working
    "context": "OutlinePanel",
    "bindings": {
      "ctrl-w": "outline_panel::ToggleFocus",
      "enter": "outline_panel::OpenSelectedEntry"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-w": "terminal_panel::ToggleFocus"
    }
  },
  {
    "context": "Editor && VimControl && !VimWaiting && !menu",
    "bindings": {
      // put key-bindings here if you want them to work in normal & visual mode
      "f": null,
      "shift-b": null,
      "shift-d": null,
      "shift-b shift-d": "pane::CloseActiveItem",
      "f u": "editor::FindAllReferences",
      "g d": "editor::GoToDefinition",
      "g b": "pane::GoBack",
      "g f": "pane::GoForward",
      "\\ f f": "file_finder::Toggle",
      "\\ f g": "workspace::NewSearch",
      "shift-k": "editor::Hover",
      "\\ t": "project_panel::ToggleFocus",
      "f o": "project_panel::ToggleFocus",
      "\\ n": "pane::ActivateNextItem",
      "\\ p": "pane::ActivatePreviousItem",
      "ctrl-o": "project_symbols::Toggle",
      "g e": "editor::GoToDiagnostic",
      "g shift-e": "editor::GoToPreviousDiagnostic",
      "\\ e": "diagnostics::Deploy",
      "\\ r": "editor::Redo",
      "g s": "editor::GoToTypeDefinition",
      "g n": "editor::Rename",
      "g i": "editor::GoToImplementation",
      "\\ s w": "tab_switcher::Toggle",
      "\\ right": "pane::SplitRight",
      "ctrl-w": "workspace::ActivateNextPane",
      "ctrl-down": "editor::AddSelectionBelow",
      "ctrl-up": "editor::AddSelectionAbove",
      "m n": "terminal_panel::ToggleFocus",
      "\\ enter": "editor::OpenExcerpts",
      "ctrl-s": "outline::Toggle",
      "\\ o l": "outline_panel::ToggleFocus",
      "\\ r t": "task::Spawn",
      "\\ m p": "markdown::OpenPreviewToTheSide",
      "\\ r n": "editor::Rename",
      "\\ a c": "agent::ToggleFocus",
      "m c": "vim::SelectNext",
      "alt-enter": "editor::ToggleCodeActions",
      "\\ c r": "editor::SplitSelectionIntoLines"
    }
  },
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "tab": "vim::Down"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-w": "workspace::ActivateNextPane",
      "left": "project_panel::CollapseSelectedEntry",
      "right": "project_panel::ExpandSelectedEntry",
      "cmd-n": "project_panel::NewFile",
      "alt-cmd-n": "project_panel::NewDirectory",
      "cmd-x": "project_panel::Cut",
      "cmd-c": "project_panel::Copy",
      "cmd-v": "project_panel::Paste",
      "cmd-alt-c": "workspace::CopyPath",
      "alt-cmd-shift-c": "workspace::CopyRelativePath",
      "space": "project_panel::Rename",
      "enter": "project_panel::Open",
      "backspace": "project_panel::Delete",
      "alt-cmd-r": "project_panel::RevealInFileManager",
      "alt-shift-f": "project_panel::NewSearchInDirectory",
      "\\ f g": "project_panel::NewSearchInDirectory"
    }
  },
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !menu",
    "bindings": {
      "d": "vim::VisualDelete",
      "alt-shift-up": "editor::MoveLineUp",
      "alt-shift-down": "editor::MoveLineDown"
    }
  },
  {
    "context": "Editor && vim_mode == insert && !menu",
    "bindings": {
      // put key-bindings here if you want them to work in insert mode
    }
  },
  {
    "context": "Agent",
    "bindings": {
      "\\ a c": "agent::ToggleFocus"
    }
  },
  {
    "context": "((vim_mode == helix_normal || vim_mode == helix_select) && !menu)",
    "bindings": {
      "\\ c r": [
        "editor::SplitSelectionIntoLines",
        {
          "keep_selections": true
        }
      ]
    }
  }
]
